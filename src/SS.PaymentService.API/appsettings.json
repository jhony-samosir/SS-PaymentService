{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "OpenTelemetry": {
    "ServiceName": "ss-payment-service",
    "Endpoint": "http://otel-collector:4317"
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672
  },
  "Midtrans": {
    "ServerKey": "",
    "ClientKey": "",
    "IsProduction": false,
    "SnapBaseUrl": "https://app.sandbox.midtrans.com",
    "ApiBaseUrl": "https://api.sandbox.midtrans.com"
  }
}
